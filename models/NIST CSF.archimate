            <property key="iso27001" value="A.12.2.1, A.12.5.1, A.14.1.2, A.14.1.3, A.14.2.4"/>
            <property key="nist-sp800-53" value="SC-16, SI-7"/>
          </element>
          <element xsi:type="archimate:Goal" name="Non-Production Environments" id="id-nist-csf-pr.ds-7">
            <documentation>The development and testing environment(s) are separate from the production environment</documentation>
            <property key="stereotype" value="ControlObjective"/>
            <property key="namespace" value="NIST_CSF"/>
            <property key="status" value="MANDATORY"/>
            <property key="refCode" value="PR.DS-7"/>
            <property key="cis_crc" value="18, 20"/>
