      <folder name="Work Packages" id="id-bbd70392108f40e58c9fa9a31844171c">
        <element xsi:type="archimate:WorkPackage" name="Business Geography Model" id="id-e5324c7b49c142de8b16a26ac0f3fd67"/>
        <element xsi:type="archimate:WorkPackage" name="Business Goals Model" id="id-05a508da794f45e9930010cce43e15dd"/>
        <element xsi:type="archimate:WorkPackage" name="Business Governance Model" id="id-66a2b1f05ef4414e9d0b72970f1d1f5b"/>
